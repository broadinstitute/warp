#!/bin/bash
# make sure there is no preexisting Docker CID file
rm -f /Users/marymorg/warp/cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays/execution/docker_cid
# run as in the original configuration without --rm flag (will remove later)
docker run \
  --cidfile /Users/marymorg/warp/cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays/execution/docker_cid \
  -i \
   \
  --entrypoint /bin/bash \
  -v /Users/marymorg/warp/cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays:/cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays:delegated \
  us.gcr.io/broad-gatk/gatk@sha256:c88912855b845bd40c6b4bc8f3dd1d4b333ed2549cd3e8386987ee7c0c284f5a /cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays/execution/script

# get the return code (working even if the container was detached)
rc=$(docker wait `cat /Users/marymorg/warp/cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays/execution/docker_cid`)

# remove the container after waiting
docker rm `cat /Users/marymorg/warp/cromwell-executions/InputQC/20cee3a0-8d38-416f-99d9-6fb0bd485b77/call-ConvertCramManifestToCramArrays/execution/docker_cid`

# return exit code
exit $rc
